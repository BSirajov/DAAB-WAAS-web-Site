# Apache redirects for renamed sponsorship page (enable mod_rewrite)
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule ^az/forum_2027_sponsorship\.html$ /az/sponsorship_partnership.html [R=301,L]
RewriteRule ^en/forum_2027_sponsorship\.html$ /en/sponsorship_partnership.html [R=301,L]
</IfModule>
