{
  "$schema": "DAAB design system — mirrors css/daab-tokens.css for JavaScript and documentation",
  "version": 1,
  "breakpoints": {
    "navCompact": 1180,
    "sidebarStack": 1060
  },
  "layout": {
    "contentMax": 1220,
    "contentMaxNarrow": 1060,
    "shellPaddingX": 24
  },
  "sticky": {
    "navHeightDesktop": 86,
    "navHeightCompact": 72,
    "breadcrumbsMinHeight": 40,
    "scrollAnchorGapRem": 1.25
  },
  "zIndex": {
    "breadcrumbs": 100,
    "hero": 1,
    "nav": 9999,
    "searchOverlay": 999999
  },
  "motion": {
    "durationFastMs": 180,
    "durationMediumMs": 220
  },
  "colors": {
    "ink": "#08263b",
    "muted": "#345f86",
    "blue700": "#0069b4",
    "blueDark": "#005a9a",
    "blueSoft": "#9ed6f5",
    "soft": "#eef7fc",
    "gold": "#c99b3b"
  },
  "typography": {
    "fontSans": "Inter, system-ui, -apple-system, \"Segoe UI\", sans-serif",
    "fontSerif": "\"Playfair Display\", Georgia, serif"
  },
  "uiText": {
    "note": "User-visible strings live in i18n/ui.json (nav, breadcrumbs, sectionNav, navIcons). Do not duplicate here."
  },
  "cssEntry": {
    "tokens": "css/daab-tokens.css",
    "common": "css/daab-common.css",
    "mobile": "css/daab-mobile.css",
    "search": "css/daab-search.css",
    "navMega": "css/daab-nav-mega.css",
    "hubCards": "css/daab-hub-cards.css",
    "heroSummary": "css/daab-hero-summary.css",
    "activitiesLayout": "css/daab-activities-layout.css",
    "pageCharter": "css/daab-charter-page.css",
    "pageFoundation": "css/daab-foundation-page.css",
    "pageMission": "css/daab-mission-page.css",
    "pageMembership": "css/daab-membership-page.css",
    "pageActivities": "css/daab-activities-page.css",
    "pageScientistsList": "css/daab-scientists-list-page.css",
    "pageScientistsProfiles": "css/daab-scientists-profiles-page.css",
    "scientistsToolbar": "css/scientists-catalog-toolbar.css"
  }
}
