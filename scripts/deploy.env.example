# Copy to scripts/deploy.env and fill in (deploy.env is gitignored via scripts/*.env pattern below).
# Used by deploy-rsync.sh and deploy-rsync.ps1

DEPLOY_HOST=your-server.example.com
DEPLOY_USER=deploy
DEPLOY_PATH=/var/www/daab-waas

# SSH port (optional, default 22)
# DEPLOY_PORT=22

# Set to 1 to delete remote files not present locally (mirror). Default: 0 (safer).
# DEPLOY_DELETE=0

# Set to 1 to skip python helpers/_validate_site.py (not recommended)
# SKIP_VALIDATE=0

# --- FTP (for scripts/deploy-ftp.sh) ---
# FTP_HOST=ftp.example.com
# FTP_USER=your-user
# FTP_PASS=your-password
# FTP_PATH=/public_html
# FTP_PORT=21
